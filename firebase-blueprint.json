{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the system",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "code": { "type": "string" },
        "lastname": { "type": "string" },
        "firstname": { "type": "string" },
        "gender": { "type": "string" },
        "dept": { "type": "string" },
        "sheet": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "code"]
    },
    "AbsenceSettings": {
      "title": "Absence Settings",
      "description": "Settings for absence sheet",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "aDir": { "type": "string" },
        "aSch": { "type": "string" },
        "aTri": { "type": "string" },
        "aFrom": { "type": "string" },
        "aTo": { "type": "string" },
        "aTeach": { "type": "string" },
        "aHalf": { "type": "string" }
      },
      "required": ["userId"]
    },
    "Pin": {
      "title": "Pin",
      "description": "Student PIN code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "name": { "type": "string" },
        "birthDate": { "type": "string" },
        "gender": { "type": "string" },
        "dept": { "type": "string" },
        "pin": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "code"]
    },
    "Permit": {
      "title": "Permit",
      "description": "Archived permit issuance",
      "type": "object",
      "properties": {
        "studentName": { "type": "string" },
        "studentDept": { "type": "string" },
        "subject": { "type": "string" },
        "type": { "type": "string" },
        "observation": { "type": "string" },
        "date": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["userId", "studentName", "date"]
    }
  },
  "firestore": {
    "students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Student roster"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/AbsenceSettings" },
      "description": "Saved settings for a user"
    },
    "pins/{pinId}": {
      "schema": { "$ref": "#/entities/Pin" },
      "description": "Student PIN codes"
    },
    "permits/{permitId}": {
      "schema": { "$ref": "#/entities/Permit" },
      "description": "Archived permits"
    }
  }
}
